# --- synthetic ground truth: regenerate with scripts/build_dataset.sh, do NOT commit ---
data/cu-ground-truth/*
!data/cu-ground-truth/.gitkeep

# --- tesstrain working state (checkpoints, unicharset, proto model) ---
training/*
!training/.gitkeep

# --- the trained model ships as a Release asset, not in the repo ---
model/*.traineddata

# --- extract_lines.py staging area: unsorted, not-yet-reviewed crops ---
data/real-lines/staging/*
!data/real-lines/staging/.gitkeep

# --- evaluation OCR cache ---
*.hyp.txt

# --- review_samples.py default output (make review writes to model/eval/, already ignored) ---
/review.png

# --- generated eval reports are fine to regenerate ---
model/eval/*
!model/eval/.gitkeep

# --- python / os ---
__pycache__/
*.pyc
.venv/
.DS_Store
.vscode/
